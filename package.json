{
  "name": "studyos",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "lint": "eslint .",
    "preview": "vite preview",
    "test": "vitest",
    "screenshot-molecule": "tsx scripts/molview-screenshot.ts",
    "extract-reagents": "tsx --env-file=.env.local scripts/extract-reagents.ts",
    "ingest-chapter": "tsx scripts/ingest-chapter.ts",
    "import-question-bank": "tsx scripts/import-question-bank.ts",
    "ingest-docx": "tsx --env-file=.env.local scripts/ingest-docx.ts",
    "parse-exam-sheet": "tsx scripts/parse-exam-sheet.ts",
    "propose-topics": "tsx --env-file=.env.local scripts/propose-topics.ts",
    "ingest-exam-pairs": "tsx --env-file=.env.local scripts/ingest-exam-pairs.ts",
    "frequency-map": "tsx --env-file=.env.local scripts/build-frequency-map.ts",
    "convert-question-map": "tsx scripts/convert-question-map.ts",
    "decompose-eas-smith": "tsx --env-file=.env.local ochem2/eas/pipeline/decompose.ts",
    "decompose-eas-patch": "tsx --env-file=.env.local ochem2/eas/pipeline/decompose-patch.ts",
    "decompose-eas-framework": "tsx --env-file=.env.local ochem2/eas/pipeline/decompose-framework.ts",
    "decompose-eas-framework-v2": "tsx --env-file=.env.local ochem2/eas/pipeline/decompose-framework-v2.ts",
    "decompose-eas-klein-mcmurry": "tsx --env-file=.env.local ochem2/eas/pipeline/decompose-klein-mcmurry.ts",
    "decompose-eas-klein-mcmurry-patch": "tsx --env-file=.env.local ochem2/eas/pipeline/decompose-klein-mcmurry-patch.ts",
    "load-eas-supabase": "tsx --env-file=.env.local ochem2/eas/pipeline/load-supabase.ts",
    "enrich-eas-problems": "tsx --env-file=.env.local ochem2/eas/pipeline/enrich-problems.ts",
    "ingest-premed-facts": "tsx --env-file=.env.local premed/pipeline/ingest-facts.ts",
    "analyze-profile": "tsx --env-file=.env.local premed/pipeline/analyze-profile.ts",
    "profile-create": "tsx --env-file=.env.local premed/pipeline/profile-cli.ts create",
    "profile-analyze": "tsx --env-file=.env.local premed/pipeline/profile-cli.ts analyze",
    "activity-add": "tsx --env-file=.env.local premed/pipeline/profile-cli.ts activity-add",
    "profile-show": "tsx --env-file=.env.local premed/pipeline/profile-cli.ts show",
    "seed-archetypes": "tsx --env-file=.env.local premed/pipeline/seed-archetypes.ts",
    "seed-schools": "tsx --env-file=.env.local premed/pipeline/seed-schools.ts",
    "scrape-class-profiles": "tsx --env-file=.env.local premed/pipeline/scrape-class-profiles.ts",
    "report-outcome": "tsx --env-file=.env.local premed/pipeline/report-outcome.ts",
    "export-demo-fixtures": "tsx --env-file=.env.local premed/pipeline/export-demo-fixtures.ts",
    "typecheck-premed": "tsc -p premed/tsconfig.json --noEmit"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.105.4",
    "pdfjs-dist": "^6.0.227",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "react-router-dom": "^7.15.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@anthropic-ai/sdk": "^0.96.0",
    "@eslint/js": "^10.0.1",
    "@tailwindcss/vite": "^4.2.4",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/jsdom": "^28.0.3",
    "@types/node": "^24.12.2",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "autoprefixer": "^10.5.0",
    "eslint": "^10.2.1",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.5.0",
    "jsdom": "^29.1.1",
    "mammoth": "^1.12.0",
    "playwright": "^1.60.0",
    "postcss": "^8.5.14",
    "tailwindcss": "^4.2.4",
    "tsx": "^4.22.1",
    "typescript": "~6.0.2",
    "typescript-eslint": "^8.58.2",
    "vite": "^8.0.10",
    "vitest": "^4.1.5",
    "xlsx": "^0.18.5"
  }
